{
  "name": "cdp-agentkit-cli",
  "version": "1.0.0",
  "description": "Coinbase CDP AgentKit CLI on Base Sepolia",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "cd gas-oracle-mcp && npm install --legacy-peer-deps && npm run build",
    "start:mcp": "node gas-oracle-mcp/dist/server.js",
    "skills:install": "npx skills add coinbase/agentic-wallet-skills --agent cursor -y",
    "skills:update": "npx skills update agentic-wallet -y",
    "dsa": "node scripts/dsa-cast.js",
    "dsa:accounts": "node scripts/dsa-cast.js accounts",
    "dsa:build-chains": "node scripts/dsa-cast.js build-chains",
    "dsa:recipes": "node scripts/dsa-cast.js recipes",
    "setup:cursor-mcp": "node scripts/setup-cursor-mcp.mjs",
    "verify:cursor-mcp": "node scripts/verify-cursor-mcp.mjs",
    "railway:diagnose": "node scripts/railway-diagnose.mjs",
    "test": "node --test index.test.js lib/instadapp/spells.test.js lib/instadapp/client.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Disseveru/CDP_AGENT_0.01.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/Disseveru/CDP_AGENT_0.01/issues"
  },
  "homepage": "https://github.com/Disseveru/CDP_AGENT_0.01#readme",
  "dependencies": {
    "@coinbase/agentkit": "^0.10.4",
    "@coinbase/agentkit-langchain": "^0.3.0",
    "@langchain/core": "^1.1.48",
    "dotenv": "^17.4.2",
    "dsa-connect": "^0.7.52",
    "web3": "^1.10.4"
  },
  "overrides": {
    "@privy-io/server-auth": "^1.32.5",
    "langsmith": "^0.7.6",
    "viem": "^2.52.2",
    "ws": "^8.21.0",
    "bigint-buffer": "npm:four-flap-bigint-buffer@^1.1.6",
    "bn.js": "^5.2.3",
    "elliptic": "^6.6.1",
    "form-data": "^4.0.6",
    "qs": "^6.14.1",
    "request": "npm:@cypress/request@^4.0.1",
    "servify": {
      "request": "npm:@cypress/request@^4.0.1"
    },
    "tar": "^7.4.3",
    "tough-cookie": "^4.1.4",
    "uuid": "^11.1.1",
    "request": {
      "form-data": "^4.0.6",
      "qs": "^6.14.1",
      "tough-cookie": "^4.1.4",
      "uuid": "^11.1.1"
    }
  }
}
