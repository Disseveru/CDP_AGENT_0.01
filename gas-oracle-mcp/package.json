{
  "name": "agentwire-mcp",
  "version": "1.0.0",
  "description": "AgentWire: x402-paid MCP server. Webhook inbox relay + real web fetch for autonomous agents that cannot receive inbound HTTP or browse the web themselves.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx src/server.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "paid-test": "tsx scripts/paid-client-test.ts",
    "paid-test:mainnet": "tsx scripts/mainnet-paid-test.ts",
    "bazaar-settle": "tsx scripts/production-bazaar-settle.ts",
    "sse-test": "tsx scripts/sse-test.ts",
    "test": "OPERATOR_SMS_NUMBER=+15555550100 node --import tsx --test src/wallet.test.ts src/payments.test.ts src/store.test.ts src/services.test.ts src/storage/file.test.ts src/storage/postgres.test.ts src/http-safety.test.ts src/deploy-env.test.ts src/captcha/captcha.test.ts",
    "migrate": "tsx src/migrate.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "dependencies": {
    "@coinbase/agentkit": "^0.10.4",
    "@coinbase/cdp-sdk": "^1.51.0",
    "@coinbase/x402": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/extensions": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "@x402/mcp": "^2.14.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.11.0",
    "ioredis": "^5.8.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.16.3",
    "viem": "^2.52.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@privy-io/server-auth": "^1.32.5",
    "viem": "^2.52.2",
    "ws": "^8.21.0",
    "bigint-buffer": "npm:four-flap-bigint-buffer@^1.1.6",
    "bn.js": "^5.2.3",
    "elliptic": "^6.6.1",
    "form-data": "^4.0.6",
    "qs": "^6.14.1",
    "uuid": "^11.1.1"
  }
}
