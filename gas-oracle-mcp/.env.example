# ============================================================
# AgentWire MCP - environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Coinbase Developer Platform credentials (https://portal.cdp.coinbase.com) ---
CDP_API_KEY=
CDP_PRIVATE_KEY=
CDP_WALLET_SECRET=

# --- Payment rail ---
# base-sepolia = testnet (free facilitator) | base = mainnet (real USDC)
NETWORK=base-sepolia

# Optional: fixed payout address (skips CDP wallet creation)
# PAY_TO_ADDRESS=0xYourAddress

# Optional facilitator override
# FACILITATOR_URL=

# --- Pricing (USD per tool call, settled in USDC) ---
PRICE_DRAIN_INBOX=$0.005
PRICE_PEEK_INBOX=$0.002
PRICE_FETCH_URL=$0.012

# --- Server ---
PORT=4021
# PUBLIC_URL=https://your-app.up.railway.app
