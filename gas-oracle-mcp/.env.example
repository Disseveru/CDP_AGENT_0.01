# ============================================================
# AgentWire MCP - environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Coinbase Developer Platform credentials (https://portal.cdp.coinbase.com) ---
# Standard CDP aliases also work: CDP_API_KEY_ID and CDP_API_KEY_SECRET
CDP_API_KEY=
CDP_PRIVATE_KEY=
CDP_WALLET_SECRET=

# --- Payment rail ---
# base = mainnet (real USDC, Bazaar-discoverable) | base-sepolia = testnet
NETWORK=base

# Optional: fixed payout address (skips CDP wallet creation and CDP key parsing)
# PAY_TO_ADDRESS=0xYourAddress

# Optional facilitator override
# When PAY_TO_ADDRESS is set and FACILITATOR_URL is empty, AgentWire defaults to
# the permissionless x402 facilitator at https://facilitator.xpay.sh
# FACILITATOR_URL=

# --- Pricing (USD per tool call, settled in USDC) ---
PRICE_DISCOVERY=$0.001
PRICE_DRAIN_INBOX=$0.005
PRICE_PEEK_INBOX=$0.002
PRICE_FETCH_URL=$0.012

# --- Server ---
PORT=4021
# PUBLIC_URL=https://your-app.up.railway.app
