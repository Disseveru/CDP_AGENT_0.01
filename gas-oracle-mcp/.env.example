# ============================================================
# AgentWire MCP - environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Coinbase Developer Platform credentials (https://portal.cdp.coinbase.com) ---
# Standard CDP aliases also work: CDP_API_KEY_ID and CDP_API_KEY_SECRET
CDP_API_KEY=
CDP_PRIVATE_KEY=
CDP_WALLET_SECRET=

# --- Payment rail ---
# base = mainnet (real USDC, Bazaar-discoverable) | base-sepolia = testnet
NETWORK=base

# Optional: fixed payout address (skips CDP wallet creation and CDP key parsing)
# PAY_TO_ADDRESS=0xYourAddress

# Optional facilitator override (defaults to the CDP facilitator recommended by the sellers quickstart)
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# For signup-free testnet testing without CDP keys:
# FACILITATOR_URL=https://x402.org/facilitator

# --- Pricing (USD per tool call, settled in USDC) ---
PRICE_DISCOVERY=$0.001
PRICE_DRAIN_INBOX=$0.005
PRICE_PEEK_INBOX=$0.002
PRICE_INBOX_STATS=$0.001
PRICE_FETCH_URL=$0.012
PRICE_EXTRACT_LINKS=$0.008
PRICE_RELAY_POST=$0.015
PRICE_CAPTCHA_SUBMIT=$0.050
PRICE_CAPTCHA_BYPASS=$0.075

# --- Human-in-the-loop CAPTCHA (operator alerts) ---
# Pick one or more channels. Twilio toll-free SMS needs 3–5 day carrier verification.
# Faster options: Gmail SMTP (mobile email notifications) or ntfy push (free app, instant).
# OPERATOR_SMS_NUMBER=+17472241814
OPERATOR_EMAIL=er2k18@gmail.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=er2k18@gmail.com
# SMTP_PASS=your-gmail-app-password
# NTFY_TOPIC=agentwire-captcha-alerts-secret-topic
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=
# CAPTCHA_TASK_TTL_SEC=3600
# CAPTCHA_POLL_TIMEOUT_MS=300000
# CAPTCHA_POLL_INTERVAL_MS=2000

# --- Server ---
PORT=4021
# PUBLIC_URL=https://gas-oracle-mcp-production.up.railway.app

# Optional: require Authorization: Bearer <key> or X-API-Key on /sse and /messages (Cursor IDE)
# MCP_API_KEY=your-random-secret

# --- Persistence (Railway production) ---
# STORAGE_BACKEND=file|postgres (auto-selects postgres when DATABASE_URL is set)
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...
# DATA_DIR=/app/gas-oracle-mcp/data/inboxes
# WEBHOOK_RATE_LIMIT=120
# WEBHOOK_RATE_WINDOW_SEC=60
