# ============================================================
# ChainPulse Gas Oracle - environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Coinbase Developer Platform credentials (https://portal.cdp.coinbase.com) ---
# API key ID (a UUID-looking string)
CDP_API_KEY=
# API key secret. Paste the whole PEM or base64 secret on ONE line; \n escapes are OK.
CDP_PRIVATE_KEY=
# Wallet secret for CDP v2 server wallets (Settings -> Wallet Secret)
CDP_WALLET_SECRET=

# --- Payment rail ---
# "base-sepolia" (testnet, free facilitator, fake USDC) or "base" (mainnet, real USDC via CDP facilitator)
NETWORK=base-sepolia

# Optional: skip CDP wallet creation and receive payments at a fixed address instead.
# PAY_TO_ADDRESS=0xYourAddress

# Optional: override the x402 facilitator. Defaults:
#   base-sepolia -> https://x402.org/facilitator
#   base         -> https://api.cdp.coinbase.com/platform/v2/x402 (requires CDP keys)
# FACILITATOR_URL=

# --- Pricing (USD, charged in USDC per tool call) ---
PRICE_GAS_SNAPSHOT=$0.001
PRICE_RECOMMEND=$0.002

# --- Server ---
PORT=4021
# Public URL agents use to reach this server (used in service metadata once deployed)
# PUBLIC_URL=https://your-app.up.railway.app
