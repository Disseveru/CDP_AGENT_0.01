{
  "mcpServers": {
    "gas-oracle-mcp": {
      "type": "sse",
      "url": "${env:GAS_ORACLE_MCP_URL}/sse",
      "headers": {
        "Authorization": "Bearer ${env:GAS_ORACLE_MCP_API_KEY}"
      }
    },
    "railway": {
      "command": "railway",
      "args": ["mcp"]
    },
    "railway-remote": {
      "url": "https://mcp.railway.com"
    },
    "railway-mcp-server": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    }
  }
}
